<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eagle</title>

    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Modern Arabic Font (Cairo) -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Eagle.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <!-- Modern Navbar -->
    <header class="site-header">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">

                <!-- Brand / Logo -->
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <div class="brand-logo">
                        <img src="~/images/Eagle.png" alt="Eagle" />
                    </div> <!--
                    <span class="brand-name">Eagle</span> -->
                </a>

                <!-- Mobile Toggle -->
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Nav Content -->
                <div class="collapse navbar-collapse" id="mainNavbar">

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav flex-grow-1 mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Sales" asp-action="Create">
                                    <i class="bi bi-cart-check"></i>
                                    تسجيل بيع
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Returns" asp-action="Create">
                                    <i class="bi bi-arrow-return-left"></i>
                                    إرجاع قطعة
                                </a>
                            </li>

                            @if (User.IsInRole("Manager"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Products" asp-action="Index">
                                        <i class="bi bi-box-seam"></i>
                                        المخزون
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Sales" asp-action="Stats">
                                        <i class="bi bi-graph-up"></i>
                                        إحصائيات المبيعات
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Sales" asp-action="History">
                                        <i class="bi bi-receipt"></i>
                                        سجل المبيعات
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Account" asp-action="Users">
                                        <i class="bi bi-people"></i>
                                        المستخدمون
                                    </a>
                                </li>
                            }
                        </ul>

                        <!-- User Info & Logout -->
                        <div class="navbar-user d-flex align-items-center gap-3">
                            <div class="user-info">
                                <i class="bi bi-person-circle"></i>
                                <span>@User.FindFirst("FullName")?.Value</span>
                            </div>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn-logout">
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span>خروج</span>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <div class="site-content">
        <div class="container">

            <!-- Success Alert -->
            @if (TempData["Success"] != null)
            {
                <div class="alert-success-custom">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>@TempData["Success"]</span>
                    <button type="button" class="alert-close" onclick="this.parentElement.remove()">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            }

            <!-- Error Alert -->
            @if (TempData["Error"] != null)
            {
                <div class="alert-error-custom">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@TempData["Error"]</span>
                    <button type="button" class="alert-close" onclick="this.parentElement.remove()">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            }

            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Modern Footer -->
    <footer class="site-footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-brand">
                    <img src="~/images/Eagle.png" alt="Eagle" class="footer-logo" />
                    <span>Eagle</span>
                </div>
                <div class="footer-copy">
                    &copy; 2026 Eagle. جميع الحقوق محفوظة.
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>

<style>
    /* ========================================
       Global Body
       ======================================== */
    body {
        font-family: 'Cairo', sans-serif;
        background-color: #f8f9fa;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .site-content {
        flex: 1;
    }

    /* ========================================
       Modern Navbar
       ======================================== */
    .site-header {
        background: linear-gradient(135deg, #212529 0%, #2c3136 100%);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        position: sticky;
        top: 0;
        z-index: 1030;
    }

    .site-header .navbar {
        padding: 0.85rem 0;
    }

    /* Brand */
    .brand-logo {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        background-color: rgba(255, 255, 255, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 4px;
        transition: transform 0.3s ease-in-out;
    }

    .brand-logo img {
        max-width: 180%;
        max-height: 180%;
        object-fit: contain;
    }

    .navbar-brand:hover .brand-logo {
        transform: scale(1.55);
        background-color: rgba(255, 255, 255, 0);
    }

    .brand-name {
        color: #ffffff;
        font-weight: 700;
        font-size: 1.25rem;
        letter-spacing: 0.5px;
    }

    /* Nav Links */
    .navbar-nav .nav-link {
        color: rgba(255, 255, 255, 0.75);
        font-weight: 500;
        font-size: 0.95rem;
        padding: 0.5rem 1rem !important;
        margin: 0 0.15rem;
        border-radius: 8px;
        transition: all 0.2s ease-in-out;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }

    .navbar-nav .nav-link i {
        font-size: 1rem;
    }

    .navbar-nav .nav-link:hover {
        color: #ffffff;
        background-color: rgba(255, 255, 255, 0.1);
    }

    .navbar-nav .nav-link.active {
        color: #ffffff;
        background-color: rgba(255, 255, 255, 0.15);
    }

    /* User Info */
    .user-info {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: rgba(255, 255, 255, 0.9);
        font-weight: 500;
        font-size: 0.9rem;
        padding: 0.4rem 0.85rem;
        background-color: rgba(255, 255, 255, 0.08);
        border-radius: 30px;
    }

    .user-info i {
        font-size: 1.1rem;
    }

    /* Logout Button */
    .btn-logout {
        background-color: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: #ffffff;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.4rem 1rem;
        border-radius: 8px;
        transition: all 0.2s ease-in-out;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        cursor: pointer;
    }

    .btn-logout:hover {
        background-color: #dc3545;
        border-color: #dc3545;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
    }

    /* Mobile Toggler */
    .navbar-toggler {
        background-color: rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 0.4rem 0.6rem;
    }

    .navbar-toggler:focus {
        box-shadow: none;
        outline: none;
    }

    /* ========================================
       Modern Alerts
       ======================================== */
    .alert-success-custom,
    .alert-error-custom {
        border-radius: 12px;
        padding: 1rem 1.25rem;
        margin: 1.5rem 0;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-weight: 500;
        position: relative;
        animation: slideDown 0.3s ease-out;
    }

    .alert-success-custom {
        background-color: #d1e7dd;
        border: 1px solid #badbcc;
        color: #0f5132;
    }

    .alert-success-custom i:first-child {
        font-size: 1.25rem;
        color: #198754;
    }

    .alert-error-custom {
        background-color: #f8d7da;
        border: 1px solid #f5c2c7;
        color: #842029;
    }

    .alert-error-custom i:first-child {
        font-size: 1.25rem;
        color: #dc3545;
    }

    .alert-close {
        background: transparent;
        border: none;
        color: inherit;
        opacity: 0.6;
        margin-right: auto;
        margin-left: 0;
        cursor: pointer;
        padding: 0.25rem;
        border-radius: 4px;
        transition: opacity 0.2s;
    }

    .alert-close:hover {
        opacity: 1;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ========================================
       Modern Footer
       ======================================== */
    .site-footer {
        background-color: #ffffff;
        border-top: 1px solid #e9ecef;
        padding: 1.5rem 0;
        margin-top: auto;
    }

    .footer-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .footer-brand {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #212529;
        font-weight: 700;
        font-size: 1rem;
    }

    .footer-logo {
        width: 28px;
        height: 28px;
        object-fit: contain;
    }

    .footer-copy {
        color: #6c757d;
        font-size: 0.9rem;
    }

    /* ========================================
       Responsive
       ======================================== */
    @@media (max-width: 991px) {
        .navbar-nav {
            padding: 1rem 0;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            margin-top: 1rem;
        }

        .navbar-nav .nav-link {
            padding: 0.75rem 1rem !important;
        }

        .navbar-user {
            padding: 1rem 0;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            margin-top: 0.5rem;
            justify-content: space-between;
            width: 100%;
        }

        .footer-content {
            flex-direction: column;
            text-align: center;
        }
    }
</style>